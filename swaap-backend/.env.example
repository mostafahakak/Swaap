PORT=4000
# Comma-separated browser origins allowed to call the API (no trailing slashes)
# Frontend dev (Next defaults to 3001 in this repo). Add production URLs as needed.
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Persistent SQLite directory (required on Render with a mounted disk). Example: /var/data
# DATA_DIR=/var/data

# Firebase Admin: paste the full JSON of your service account key (one line), or use a file path below.
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# Optional: path to service account JSON file instead of FIREBASE_SERVICE_ACCOUNT
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-adminsdk.json
